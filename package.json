{
  "name": "domodoro",
  "version": "0.3.1",
  "description": "A dominant Pomodoro timer for forced breaks, bilingual UI, and extensible overlay packs.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "check": "npm test",
    "build": "electron-builder --dir",
    "dist": "electron-builder --win nsis zip --publish never"
  },
  "keywords": [
    "domodoro",
    "pomodoro",
    "electron",
    "adhd",
    "break",
    "windows"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.domodoro.app",
    "productName": "Domodoro",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "README.md",
      "LICENSE",
      "package.json"
    ],
    "win": {
      "icon": "src/assets/breaklock-icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Domodoro"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "chart.js": "^4.5.1",
    "lucide": "^1.24.0"
  }
}
